<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hasini Kadaru — Architectural Designer</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink:     #1a1814;
    --mid:     #5a554e;
    --faint:   #9a948c;
    --rule:    #ddd9d3;
    --paper:   #f7f4ef;
    --warm:    #f0ece4;
    --accent:  #2a5c8f;
    --serif:   'Cormorant Garamond', Georgia, serif;
    --mono:    'DM Mono', monospace;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ── NOISE TEXTURE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 999;
    opacity: 0.4;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.4rem 3rem;
    background: rgba(247, 244, 239, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--rule);
  }

  .nav-name {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--ink);
    text-decoration: none;
  }

  .nav-name span {
    font-weight: 300;
    color: var(--accent);
    font-size: 0.75rem;
    font-family: var(--mono);
    margin-left: 0.5rem;
    letter-spacing: 0.08em;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mid);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--ink); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-top: 5rem;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 5rem 3rem 5rem 3rem;
    border-right: 1px solid var(--rule);
  }

  .hero-eyebrow {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .hero-name {
    font-size: clamp(3.5rem, 6vw, 5.5rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 0.3rem;
  }

  .hero-name em {
    font-style: italic;
    font-weight: 300;
    color: var(--mid);
  }

  .hero-credential {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 2.5rem;
    margin-top: 0.8rem;
  }

  .hero-desc {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--mid);
    max-width: 420px;
    line-height: 1.75;
    margin-bottom: 3rem;
  }

  .hero-cta {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .btn-primary {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    padding: 0.85rem 1.8rem;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .btn-primary:hover { background: var(--accent); }

  .btn-secondary {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mid);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .btn-secondary:hover { color: var(--ink); border-color: var(--ink); }

  .hero-right {
    display: grid;
    grid-template-rows: 1fr 1fr;
    background: var(--warm);
  }

  .hero-stat-block {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem;
    border-bottom: 1px solid var(--rule);
  }

  .hero-stat-block:last-child { border-bottom: none; }

  .stat-number {
    font-size: 3.5rem;
    font-weight: 300;
    color: var(--ink);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faint);
  }

  /* ── SECTION SHARED ── */
  section { padding: 6rem 3rem; }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--rule);
  }

  .section-title {
    font-size: 0.68rem;
    font-family: var(--mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .section-count {
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--faint);
  }

  /* ── WORK GRID ── */
  #work { background: var(--paper); }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }

  .project-card {
    background: var(--paper);
    cursor: pointer;
    overflow: hidden;
    transition: background 0.3s;
    position: relative;
  }

  .project-card:hover { background: var(--warm); }

  .project-card:hover .project-image-placeholder { opacity: 0.85; }
  .project-card:hover .project-image-placeholder::after { opacity: 1; }

  .project-image-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: var(--warm);
    position: relative;
    overflow: hidden;
    transition: opacity 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Architectural grid pattern for placeholders */
  .project-image-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--rule) 1px, transparent 1px),
      linear-gradient(90deg, var(--rule) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.6;
  }

  .placeholder-label {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .placeholder-icon {
    width: 48px;
    height: 48px;
    border: 1px solid var(--faint);
    margin: 0 auto 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-icon svg { width: 22px; height: 22px; stroke: var(--faint); fill: none; }

  .placeholder-text {
    font-family: var(--mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--faint);
  }

  /* When you have a real image — add class .has-image and set background-image */
  .project-image-placeholder.has-image::before { display: none; }
  .project-image-placeholder.has-image .placeholder-label { display: none; }

  .project-info {
    padding: 1.6rem 2rem 2rem;
    border-top: 1px solid var(--rule);
  }

  .project-meta {
    font-family: var(--mono);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faint);
    margin-bottom: 0.5rem;
    display: flex;
    gap: 1rem;
  }

  .project-title {
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .project-desc {
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.65;
    margin-bottom: 1.2rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-family: var(--mono);
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid rgba(42, 92, 143, 0.25);
    padding: 0.2rem 0.6rem;
  }

  /* ── ABOUT ── */
  #about {
    background: var(--warm);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 5rem;
    align-items: start;
  }

  .about-left { position: sticky; top: 7rem; }

  .about-photo-placeholder {
    width: 100%;
    aspect-ratio: 3/4;
    background: var(--rule);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .about-photo-placeholder svg { width: 32px; height: 32px; stroke: var(--faint); fill: none; }

  .about-photo-placeholder p {
    font-family: var(--mono);
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .about-name-side {
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.2rem;
  }

  .about-title-side {
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .about-right h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 300;
    line-height: 1.3;
    color: var(--ink);
    margin-bottom: 2rem;
  }

  .about-right h2 em {
    font-style: italic;
    color: var(--mid);
  }

  .about-body {
    font-size: 1rem;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 3rem;
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--rule);
  }

  .skill-group-label {
    font-family: var(--mono);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faint);
    margin-bottom: 0.4rem;
  }

  .skill-group-items {
    font-size: 0.88rem;
    color: var(--mid);
    font-weight: 300;
    line-height: 1.6;
  }

  /* ── CONTACT ── */
  #contact { background: var(--ink); }

  #contact .section-title { color: rgba(247, 244, 239, 0.4); }
  #contact .section-header { border-color: rgba(247, 244, 239, 0.1); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-headline {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 300;
    line-height: 1.2;
    color: var(--paper);
    margin-bottom: 1.5rem;
  }

  .contact-headline em { font-style: italic; color: var(--faint); }

  .contact-sub {
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--faint);
    line-height: 1.75;
    margin-bottom: 2.5rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .contact-link-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-bottom: 1.2rem;
    border-bottom: 1px solid rgba(247, 244, 239, 0.08);
  }

  .contact-link-label {
    font-family: var(--mono);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(247, 244, 239, 0.3);
    width: 5rem;
    flex-shrink: 0;
  }

  .contact-link-value {
    font-size: 0.95rem;
    color: var(--paper);
    text-decoration: none;
    font-weight: 300;
    transition: color 0.2s;
  }

  .contact-link-value:hover { color: rgba(42, 92, 143, 0.9); }

  .contact-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 1rem;
  }

  .availability-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #6db87a;
    margin-bottom: 2rem;
  }

  .availability-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6db87a;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .resume-download {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem;
    border: 1px solid rgba(247, 244, 239, 0.12);
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
    group: true;
  }

  .resume-download:hover {
    border-color: rgba(247, 244, 239, 0.3);
    background: rgba(247, 244, 239, 0.03);
  }

  .resume-download-text { }

  .resume-download-label {
    font-family: var(--mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(247, 244, 239, 0.3);
    margin-bottom: 0.3rem;
  }

  .resume-download-title {
    font-size: 1rem;
    color: var(--paper);
    font-weight: 300;
  }

  .resume-download-arrow {
    font-size: 1.2rem;
    color: rgba(247, 244, 239, 0.3);
    transition: transform 0.2s, color 0.2s;
  }

  .resume-download:hover .resume-download-arrow {
    transform: translateX(4px);
    color: var(--paper);
  }

  /* ── FOOTER ── */
  footer {
    background: var(--ink);
    padding: 1.5rem 3rem;
    border-top: 1px solid rgba(247, 244, 239, 0.08);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  footer p {
    font-family: var(--mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: rgba(247, 244, 239, 0.2);
    text-transform: uppercase;
  }

  /* ── ANIMATIONS ── */
  .fade-up {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* stagger children */
  .fade-up:nth-child(1) { transition-delay: 0s; }
  .fade-up:nth-child(2) { transition-delay: 0.1s; }
  .fade-up:nth-child(3) { transition-delay: 0.2s; }
  .fade-up:nth-child(4) { transition-delay: 0.3s; }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { gap: 1.5rem; }
    .hero { grid-template-columns: 1fr; }
    .hero-right { display: none; }
    .hero-left { padding: 3rem 1.5rem; min-height: 90vh; justify-content: center; }
    section { padding: 4rem 1.5rem; }
    .work-grid { grid-template-columns: 1fr; }
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-left { position: static; }
    .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
